---
/**
 * ImageZoom Component
 * Provides a lightbox effect for images within the `.markdown-body` content area.
 * Follows SRP by isolating the lightbox HTML and its associated behavior.
 */
import { Icon } from 'astro-icon/components';
---

<image-zoom>
  <!-- Image Zoom Overlay -->
  <div
    aria-hidden="true"
    class="fixed inset-0 z-100 hidden bg-slate-950/90 backdrop-blur-md cursor-zoom-out items-center justify-center transition-all duration-300 opacity-0"
    id="image-zoom-overlay"
  >
    <img
      alt="Zoomed image"
      class="max-w-[95vw] max-h-[95vh] object-contain shadow-2xl scale-95 transition-transform duration-500 ease-out rounded-xl select-none"
      id="image-zoom-img"
      src=""
    />
    <div
      class="absolute top-4 right-4 p-2 text-white/50 hover:text-white transition-colors bg-white/10 hover:bg-white/20 rounded-full cursor-pointer flex items-center justify-center"
      id="image-zoom-close"
      title="Close (Esc)"
    >
      <Icon name="bi:x-lg" size={24} />
    </div>
  </div>
</image-zoom>

<script>
  class ImageZoom extends HTMLElement {
    private overlay: HTMLElement | null = null;
    private zoomImg: HTMLImageElement | null = null;
    private closeBtn: HTMLElement | null = null;
    private images: NodeListOf<HTMLImageElement> | null = null;
    private imageClickListeners = new Map<HTMLImageElement, () => void>();

    connectedCallback() {
      this.overlay = this.querySelector('#image-zoom-overlay');
      this.zoomImg = this.querySelector('#image-zoom-img');
      this.closeBtn = this.querySelector('#image-zoom-close');

      if (!this.overlay || !this.zoomImg) {
        return;
      }

      this.images = document.querySelectorAll('.markdown-body img') as NodeListOf<HTMLImageElement>;
      this.images.forEach((img) => {
        // 避免與已被連結包裹的圖片衝突
        if (img.parentElement?.tagName === 'A') {
          return;
        }

        img.style.cursor = 'zoom-in';
        const clickListener = () => this.openZoom(img.src);
        img.addEventListener('click', clickListener);
        this.imageClickListeners.set(img, clickListener);
      });

      this.overlay.addEventListener('click', this.handleOverlayClick);
      this.closeBtn?.addEventListener('click', this.closeZoom);
      window.addEventListener('keydown', this.handleKeyDown);
    }

    disconnectedCallback() {
      if (this.images) {
        this.images.forEach((img) => {
          const listener = this.imageClickListeners.get(img);
          if (listener) {
            img.removeEventListener('click', listener);
          }
        });
      }
      this.imageClickListeners.clear();

      this.overlay?.removeEventListener('click', this.handleOverlayClick);
      this.closeBtn?.removeEventListener('click', this.closeZoom);
      window.removeEventListener('keydown', this.handleKeyDown);
    }

    private openZoom(src: string) {
      if (!this.overlay || !this.zoomImg) return;
      this.zoomImg.src = src;
      this.overlay.classList.remove('hidden');
      this.overlay.classList.add('flex');

      requestAnimationFrame(() => {
        if (this.overlay && this.zoomImg) {
          this.overlay.style.opacity = '1';
          this.zoomImg.style.transform = 'scale(1)';
        }
      });

      document.body.style.overflow = 'hidden';
    }

    private closeZoom = () => {
      if (!this.overlay || !this.zoomImg) return;
      this.overlay.style.opacity = '0';
      this.zoomImg.style.transform = 'scale(0.95)';

      setTimeout(() => {
        if (this.overlay && this.zoomImg) {
          this.overlay.classList.add('hidden');
          this.overlay.classList.remove('flex');
          this.zoomImg.src = '';
        }
        document.body.style.overflow = '';
      }, 300);
    };

    private handleOverlayClick = (e: MouseEvent) => {
      if (e.target !== this.zoomImg) {
        this.closeZoom();
      }
    };

    private handleKeyDown = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && this.overlay && !this.overlay.classList.contains('hidden')) {
        this.closeZoom();
      }
    };
  }

  customElements.define('image-zoom', ImageZoom);
</script>
