---
import type { CategoryPostItem } from '../utils/posts';

interface Props {
  activeId?: string;
  recentPosts: CategoryPostItem[];
  tagCloud: Array<{ count: number; tag: string }>;
}

const { activeId, recentPosts, tagCloud } = Astro.props;
---

<div class="hidden lg:block max-w-54 sticky top-0 self-start">
  <!-- 近期文章 -->
  <nav aria-label="近期文章" class="mb-8">
    <h3 class="text-sm font-bold text-primary pb-2">近期文章</h3>
    <ul class="space-y-1">
      {
        recentPosts.map((post) => (
          <li>
            <a
              class:list={[
                'block p-3 rounded-xl transition-all duration-200 group truncate',
                activeId === post.id
                  ? 'bg-primary/10 text-primary font-bold '
                  : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-primary dark:hover:text-primary',
              ]}
              href={post.url}
              title={post.title}
            >
              <div class="text-sm leading-relaxed line-clamp-2 group-hover:translate-x-1 transition-transform">
                {post.title}
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- 標籤雲 -->
  <nav aria-label="標籤雲">
    <h3 class="text-sm font-bold text-primary mb-2 pb-2">標籤</h3>
    <div class="flex flex-wrap gap-2">
      {
        tagCloud.map(({ count, tag }) => (
          <a
            class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 hover:border-primary hover:text-primary dark:hover:text-primary hover:bg-primary/5 transition-all"
            href={`/posts/tag/${encodeURIComponent(tag)}`}
            title={`${tag} (${count})`}
          >
            {tag}
            <span class="ml-1.5 opacity-50 px-1.5 bg-slate-200 dark:bg-slate-800 rounded-full group-hover:bg-primary/20">
              {count}
            </span>
          </a>
        ))
      }
    </div>
  </nav>
</div>
