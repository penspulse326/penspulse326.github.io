---
import { Image } from 'astro:assets';

import type { CategoryWithContent } from '../../utils/content';
import type { CategoryPostItem } from '../../utils/posts';

import ContentMenu from './content-menu.astro';
import PostsMenu from './posts-menu.astro';
import ThemeToggler from './theme-toggler.astro';
import Search from 'astro-pagefind/components/Search';

import logoImage from '/public/logo.png';

const pathname = Astro.url.pathname;
const isNotesRoute = pathname.startsWith('/notes');
const isPlansRoute = pathname.startsWith('/plans');
const isPostsRoute = pathname.startsWith('/posts');
const isContentRoute = isNotesRoute || isPlansRoute;
const hasCustomMenu = isContentRoute || isPostsRoute;

const normalizePath = (path: string) => (path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path);

// 輔助函式：查找當前頁面的 active ID
const findActiveId = (navigation: CategoryWithContent[], currentPath: string) => {
  for (const category of navigation) {
    for (const item of category.items) {
      if (normalizePath(item.url) === currentPath) return item.id;
    }
  }
  return undefined;
};

let contentNavigation: CategoryWithContent[] = [];
let activeContentId: string | undefined;
let postsRecentPosts: CategoryPostItem[] = [];
let postsTagCloud: Array<{ count: number; tag: string }> = [];
let activePostId: string | undefined;

if (isNotesRoute) {
  const { getNavigation } = await import('../../utils/notes');
  contentNavigation = getNavigation().map((cat) => ({ ...cat, items: cat.notes }));
  activeContentId = findActiveId(contentNavigation, normalizePath(pathname));
} else if (isPlansRoute) {
  const { getNavigation } = await import('../../utils/plans');
  contentNavigation = getNavigation().map((cat) => ({ ...cat, items: cat.plans }));
  activeContentId = findActiveId(contentNavigation, normalizePath(pathname));
} else if (isPostsRoute) {
  const { getRecentPosts, getTagCloud } = await import('../../utils/posts');
  postsRecentPosts = getRecentPosts(5);
  postsTagCloud = getTagCloud();
  const pathParts = pathname.split('/').filter(Boolean);
  activePostId = pathParts.length > 1 ? pathParts[pathParts.length - 1] : undefined;
}
---

<nav
  class="w-full bg-white/80 dark:bg-slate-950/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 sticky top-0 z-50"
>
  <div class="max-w-7xl mx-auto px-4 lg:px-8">
    <!-- 手機版導覽列 (Logo, 搜尋, 選單按鈕) - 僅在小於 lg 螢幕顯示 -->
    <div class="flex lg:hidden items-center justify-between h-16 gap-4">
      <div class="flex-shrink-0">
        <a class="flex items-center" href="/">
          <Image
            alt="Pen's Pulse Logo"
            class="h-8 w-8"
            densities={[1.5, 2, 3]}
            format="webp"
            height={32}
            quality={90}
            src={logoImage}
            width={32}
          />
        </a>
      </div>
      <div class="flex-grow max-w-md" style="min-width: 0;">
        <Search id="mobile-nav-search" className="pagefind-custom w-full" uiOptions={{ showImages: false }} />
      </div>
      <div class="flex-shrink-0">
        <button
          aria-controls="mobile-menu"
          aria-label="Toggle navigation"
          class="p-2 rounded-md text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 focus:outline-none"
          id="mobile-menu-button"
          type="button"
        >
          <span class="bi bi-list text-2xl"></span>
        </button>
      </div>
    </div>

    <!-- 桌面版導覽列 - 僅在 lg 以上顯示 -->
    <div class="hidden lg:flex items-center justify-between h-16">
      <!-- 左欄 -->
      <div class="flex items-center gap-8">
        <!-- Logo -->
        <a class="flex items-center shrink-0" href="/">
          <Image
            alt="Pen's Pulse 首頁"
            class="h-8 w-8 rounded-full"
            densities={[1.5, 2, 3]}
            format="webp"
            height={32}
            quality={100}
            src={logoImage}
            width={32}
          />
          <span class="ml-3 text-xl font-bold text-slate-900 dark:text-white">Pen's Pulse</span>
        </a>

        <!-- 站內連結 -->
        <ul class="flex items-center gap-1">
          <li>
            <a
              class={`px-3 py-2 text-sm font-medium transition-colors hover:text-primary ${isPostsRoute ? 'text-primary' : 'text-slate-600 dark:text-slate-400'}`}
              href="/posts"
            >
              文章
            </a>
          </li>
          <li>
            <a
              class={`px-3 py-2 text-sm font-medium transition-colors hover:text-primary ${isNotesRoute ? 'text-primary' : 'text-slate-600 dark:text-slate-400'}`}
              href="/notes"
            >
              研究筆記
            </a>
          </li>
          <li>
            <a
              class={`px-3 py-2 text-sm font-medium transition-colors hover:text-primary ${isPlansRoute ? 'text-primary' : 'text-slate-600 dark:text-slate-400'}`}
              href="/plans"
            >
              挑戰計畫
            </a>
          </li>
        </ul>
      </div>

      <!-- 右欄 -->
      <div class="flex items-center gap-4">
        <!-- 搜尋框 -->
        <div class="w-64">
          <Search id="desktop-search" className="pagefind-custom" uiOptions={{ showImages: false }} />
        </div>

        <!-- 外部連結 -->
        <a
          aria-label="前往 GitHub 查看專案"
          class="text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors"
          href="https://github.com/penspulse326"
          rel="noopener noreferrer"
          target="_blank"
        >
          <span aria-hidden="true" class="bi bi-github text-xl"></span>
        </a>

        <!-- 主題切換 -->
        <ThemeToggler />
      </div>
    </div>

    <!-- 手機版下拉選單 -->
    <div class="hidden lg:hidden border-t border-slate-200 dark:border-slate-800" id="mobile-menu">
      <div class="px-2 pt-2 pb-3 space-y-1">
        <a
          class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800"
          href="/posts">文章</a
        >
        <a
          class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800"
          href="/notes">研究筆記</a
        >
        <a
          class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800"
          href="/plans">挑戰計畫</a
        >

        <div class="border-t border-slate-200 dark:border-slate-800 my-2"></div>

        <a
          class="flex items-center px-3 py-2 rounded-md text-base font-medium text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800"
          href="https://github.com/penspulse326"
          target="_blank"
        >
          <span aria-hidden="true" class="bi bi-github mr-2"></span>
          GitHub
        </a>

        <div
          class="flex items-center px-3 py-2 rounded-md transition-colors hover:bg-slate-100 dark:hover:bg-slate-800 cursor-pointer"
          id="mobile-theme-toggle-container"
        >
          <ThemeToggler />
          <span class="ml-2 text-base font-medium text-slate-700 dark:text-slate-200">主題切換</span>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileThemeToggleContainer = document.getElementById('mobile-theme-toggle-container');

  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  mobileThemeToggleContainer?.addEventListener('click', () => {
    const toggler = mobileThemeToggleContainer.querySelector('#bd-theme') as HTMLElement;
    toggler?.click();
  });
</script>

<style>
  .navbar {
    height: 60px;
  }

  /* 搜尋按鈕樣式 */
  .bd-search {
    position: relative;
    margin: 0;
  }

  .search-button:hover,
  .search-button:focus {
    background-color: var(--bs-body-bg);
    border-color: var(--bs-primary);
    color: var(--bs-body-color);
  }

  .search-button:hover {
    box-shadow: 0 0 0 3px rgb(var(--bs-primary-rgb), 0.1);
  }

  .search-button:focus {
    box-shadow: 0 0 0 3px rgb(var(--bs-primary-rgb), 0.25);
    outline: 0;
  }

  .search-button-container {
    align-items: center;
    display: flex;
    gap: 0.5rem;
    pointer-events: none;
  }

  .search-icon {
    color: var(--bs-secondary-color);
    flex-shrink: 0;
  }

  .search-placeholder {
    color: var(--bs-secondary-color);
    opacity: 0.75;
  }

  .search-keys {
    align-items: center;
    display: flex;
    gap: 0.25rem;
    pointer-events: none;
  }

  .search-key {
    align-items: center;
    background-color: var(--bs-tertiary-bg);
    border: 1px solid var(--bs-border-color);
    border-bottom: 2px solid var(--bs-gray-500);
    border-radius: 0.25rem;
    color: var(--bs-secondary-color);
    display: inline-flex;
    font-family: var(--bs-font-monospace);
    font-size: 1em;
    height: 1.5em;
    justify-content: center;
    line-height: 1.2;
    min-width: 1.2em;
    padding: 0 0.5em;
    white-space: nowrap;
  }

  .search-key-icon {
    color: var(--bs-secondary-color);
  }

  /* 導覽列網格佈局 - 三欄式，中間欄位固定寬度 */
  .navbar-grid-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    width: 100%;
  }

  /* 導覽連結 hover 效果 */
  .nav-link span {
    position: relative;
    text-decoration: none;
    transition: all 0.15s ease;
    color: var(--bs-body-color);
  }

  .nav-link span::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -4px;
    left: 0;
    background-color: var(--bs-primary);
    transition: width 0.15s ease;
  }

  .nav-link:hover span::after {
    width: 100%;
  }

  /* 導覽連結 active 狀態 */
  .nav-link.active span {
    color: var(--bs-primary);
  }

  .nav-link.active span::after {
    width: 100%;
  }

  /* 外部連結 hover 效果 */
  .text-opacity-75-hover:hover {
    opacity: 1 !important;
  }

  [data-bs-theme='light'] .text-opacity-75-hover:hover {
    color: var(--bs-body-color) !important;
  }

  /* 側邊選單平滑過渡效果 */
  .offcanvas {
    transition: transform 0.3s ease-in-out;
  }

  /* 手機版選單項目間距 */
  .offcanvas-body .nav-item {
    margin: 0.5rem 0;
  }

  /* 側邊選單關閉按鈕樣式 */
  .offcanvas-header .btn-close {
    margin: -0.5rem -0.5rem -0.5rem auto;
    padding: 0.5rem;
  }

  /* 側邊選單連結樣式 */
  .offcanvas-body a {
    border-radius: 0.375rem;
    transition: background-color 0.2s;
  }

  .offcanvas-body a:hover {
    background-color: rgb(0 0 0 / 5%);
  }

  [data-bs-theme='dark'] .offcanvas-body a:hover {
    background-color: rgb(255 255 255 / 10%);
  }

  [data-bs-theme='dark'] .text-opacity-75-hover {
    color: var(--bs-body-color) !important;
    opacity: 0.75;
  }

  .notes-drawer .accordion-button {
    padding: 0.5rem 0;
  }

  .notes-drawer-item + .notes-drawer-item {
    border-top: 1px solid var(--bs-border-color-translucent);
  }

  .notes-drawer-link {
    display: block;
    padding: 0.625rem 0;
    text-decoration: none;
    color: inherit;
    font-size: 0.95rem;
  }

  .notes-drawer-link.active {
    font-weight: 600;
    color: var(--bs-primary);
  }
</style>
