---
// PSP 波浪特效 - 模擬 PlayStation 3/PSP 的 XMB 波浪背景
// 使用 Three.js 實現流動的波浪線條
---

<div id="psp-waves-container"></div>

<style>
  #psp-waves-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: hidden;

    /* 初始背景色 */
    background: linear-gradient(to bottom, #00a8a5 0%, #0861c5 100%);
    z-index: 0;
  }

  #psp-waves-container canvas {
    display: block;
  }
</style>

<script>
  let isInitialized = false;

  async function initWaves() {
    if (isInitialized) return;

    const container = document.getElementById('psp-waves-container') as HTMLDivElement;

    if (!container) {
      if (document.readyState !== 'complete') {
        window.addEventListener('load', () => initWaves(), { once: true });
      }
      return;
    }

    isInitialized = true;

    // 動態引入所需的 three 模組 (Tree shaking 友好)
    const {
      Scene,
      PerspectiveCamera,
      WebGLRenderer,
      Mesh,
      PlaneGeometry,
      MeshBasicMaterial,
      DoubleSide,
      AdditiveBlending,
    } = await import('three');

    // 配置參數
    const config = {
      yOffset: -500,
    };

    // 建立場景
    const scene = new Scene();

    // 透視相機
    const fov = 75;
    const aspect = container.offsetWidth / container.offsetHeight;
    const near = 1;
    const far = 10000;
    const camera = new PerspectiveCamera(fov, aspect, near, far);
    camera.position.set(0, 0, 1000);
    camera.lookAt(0, 0, 0);

    const renderer = new WebGLRenderer({
      alpha: true,
      antialias: true,
    });

    const isMobile = window.innerWidth < 768;

    renderer.setSize(container.offsetWidth, container.offsetHeight);
    renderer.setPixelRatio(isMobile ? 1 : Math.min(window.devicePixelRatio, 2));
    container.appendChild(renderer.domElement);

    const waves: any[] = [];
    const waveParams = [
      { color: 0xffffff, opacity: 0.15, z: 0, speed: 0.3, offset: 0, amplitude: 200 },
      { color: 0xffffff, opacity: 0.1, z: -100, speed: 0.9, offset: 200, amplitude: 150 },
      { color: 0xffffff, opacity: 0.05, z: -200, speed: 0.6, offset: 400, amplitude: 100 },
    ];

    const planeWidth = 12000;
    const planeSegments = isMobile ? 30 : 50;

    waveParams.forEach((param) => {
      const geometry = new PlaneGeometry(planeWidth, 1200, planeSegments, 1);
      const material = new MeshBasicMaterial({
        color: param.color,
        transparent: true,
        opacity: param.opacity,
        side: DoubleSide,
        depthWrite: false,
        blending: AdditiveBlending,
      });

      const mesh = new Mesh(geometry, material);
      mesh.position.z = param.z;
      mesh.position.y = config.yOffset;

      // 儲存原始頂點數據用於動畫計算
      const positions = geometry.attributes.position.array;
      const baseVertices: number[] = [];
      for (let i = 0; i < positions.length; i++) {
        baseVertices.push(positions[i]);
      }

      mesh.userData = {
        speed: param.speed,
        offset: param.offset,
        baseVertices: baseVertices,
        amplitude: param.amplitude,
      };

      scene.add(mesh);
      waves.push(mesh);
    });

    function animate(currentTime: number) {
      requestAnimationFrame(animate);
      const time = currentTime * 0.001;

      waves.forEach((mesh) => {
        const positions = mesh.geometry.attributes.position.array as Float32Array;
        const count = mesh.geometry.attributes.position.count;
        const baseVertices = mesh.userData.baseVertices;

        for (let i = 0; i < count; i++) {
          const x = baseVertices[i * 3];
          const waveX = x * 0.0005 + mesh.userData.offset;
          const t = time * mesh.userData.speed;

          const movement =
            Math.sin(waveX + t) * mesh.userData.amplitude +
            Math.sin(waveX * 2 + t * 1.5) * (mesh.userData.amplitude * 0.5);

          positions[i * 3 + 1] = baseVertices[i * 3 + 1] + movement;
        }

        mesh.geometry.attributes.position.needsUpdate = true;
      });

      renderer.render(scene, camera);
    }

    // 啟動動畫
    requestAnimationFrame(animate);

    // Resize 處理
    function handleResize() {
      if (!container) return;
      const width = container.offsetWidth;
      const height = container.offsetHeight;
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
      renderer.setSize(width, height);
    }

    window.addEventListener('resize', handleResize);
    window.dispatchEvent(new CustomEvent('threejs-ready'));

    // 清理
    const cleanup = () => {
      window.removeEventListener('resize', handleResize);
      renderer.dispose();
      scene.traverse((object) => {
        if (object instanceof Mesh) {
          object.geometry.dispose();
          if (Array.isArray(object.material)) {
            object.material.forEach((m) => m.dispose());
          } else {
            object.material.dispose();
          }
        }
      });
    };

    window.addEventListener('beforeunload', cleanup);
  }

  // 使用 requestIdleCallback 延遲啟動即可解決 TBT 問題
  const scheduleInit = () => {
    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(() => initWaves(), { timeout: 3000 });
    } else {
      setTimeout(initWaves, 1000);
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', scheduleInit);
  } else {
    scheduleInit();
  }
</script>
