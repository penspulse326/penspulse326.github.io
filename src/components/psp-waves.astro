---
// PSP 波浪特效 - 模擬 PlayStation 3/PSP 的 XMB 波浪背景
// 使用 Three.js 實現流動的波浪線條
---

<psp-waves class="absolute inset-0 pointer-events-none overflow-hidden z-0">
  <div class="waves-container w-full h-full"></div>
</psp-waves>

<style>
  psp-waves {
    display: block;
  }

  .waves-container {
    /* 初始背景色 */
    background: linear-gradient(to bottom, #00a8a5 0%, #0861c5 100%);
  }

  .waves-container canvas {
    display: block;
  }
</style>

<script>
  class PspWaves extends HTMLElement {
    private container: HTMLDivElement | null = null;
    private renderer: any = null;
    private scene: any = null;
    private camera: any = null;
    private animationFrameId: number | null = null;
    private observer: IntersectionObserver | null = null;
    private isPaused = false;
    private waves: any[] = [];
    private resizeListener: (() => void) | null = null;

    connectedCallback() {
      this.container = this.querySelector('.waves-container');
      if (!this.container) return;

      // 監聽可見度優化效能
      this.observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              if (this.isPaused) {
                this.isPaused = false;
                this.animate();
              }
            } else {
              this.isPaused = true;
            }
          });
        },
        { threshold: 0.1 },
      );
      this.observer.observe(this);

      // 使用 requestIdleCallback 延遲啟動以優化 TBT
      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(() => this.initWaves(), { timeout: 3000 });
      } else {
        setTimeout(() => this.initWaves(), 1000);
      }
    }

    disconnectedCallback() {
      this.cleanup();
    }

    private async initWaves() {
      if (!this.container) return;

      // 動態引入所需的 three 模組 (Tree shaking 友好)
      const {
        Scene,
        PerspectiveCamera,
        WebGLRenderer,
        Mesh,
        PlaneGeometry,
        MeshBasicMaterial,
        DoubleSide,
        AdditiveBlending,
      } = await import('three');

      const config = {
        yOffset: -500,
      };

      this.scene = new Scene();

      // 透視相機
      const fov = 75;
      const aspect = this.container.offsetWidth / this.container.offsetHeight;
      const near = 1;
      const far = 10000;
      this.camera = new PerspectiveCamera(fov, aspect, near, far);
      this.camera.position.set(0, 0, 1000);
      this.camera.lookAt(0, 0, 0);

      this.renderer = new WebGLRenderer({
        alpha: true,
        antialias: true,
      });

      const isMobile = window.innerWidth < 768;

      this.renderer.setSize(this.container.offsetWidth, this.container.offsetHeight);
      this.renderer.setPixelRatio(isMobile ? 1 : Math.min(window.devicePixelRatio, 2));
      this.container.appendChild(this.renderer.domElement);

      const waveParams = [
        { color: 0xffffff, opacity: 0.15, z: 0, speed: 0.3, offset: 0, amplitude: 200 },
        { color: 0xffffff, opacity: 0.1, z: -100, speed: 0.9, offset: 200, amplitude: 150 },
        { color: 0xffffff, opacity: 0.05, z: -200, speed: 0.6, offset: 400, amplitude: 100 },
      ];

      const planeWidth = 12000;
      const planeSegments = isMobile ? 30 : 50;

      waveParams.forEach((param) => {
        const geometry = new PlaneGeometry(planeWidth, 1200, planeSegments, 1);
        const material = new MeshBasicMaterial({
          color: param.color,
          transparent: true,
          opacity: param.opacity,
          side: DoubleSide,
          depthWrite: false,
          blending: AdditiveBlending,
        });

        const mesh = new Mesh(geometry, material);
        mesh.position.z = param.z;
        mesh.position.y = config.yOffset;

        const positions = geometry.attributes.position.array;
        const baseVertices: number[] = [];
        for (let i = 0; i < positions.length; i++) {
          baseVertices.push(positions[i]);
        }

        mesh.userData = {
          speed: param.speed,
          offset: param.offset,
          baseVertices: baseVertices,
          amplitude: param.amplitude,
        };

        this.scene.add(mesh);
        this.waves.push(mesh);
      });

      this.animate();

      this.resizeListener = () => {
        if (!this.container || !this.camera || !this.renderer) return;
        const width = this.container.offsetWidth;
        const height = this.container.offsetHeight;
        this.camera.aspect = width / height;
        this.camera.updateProjectionMatrix();
        this.renderer.setSize(width, height);
      };

      window.addEventListener('resize', this.resizeListener);
      window.dispatchEvent(new CustomEvent('threejs-ready'));
    }

    private animate = () => {
      if (this.isPaused || !this.renderer || !this.scene || !this.camera) return;

      this.animationFrameId = requestAnimationFrame(this.animate);
      const time = performance.now() * 0.001;

      this.waves.forEach((mesh) => {
        const positions = mesh.geometry.attributes.position.array as Float32Array;
        const count = mesh.geometry.attributes.position.count;
        const baseVertices = mesh.userData.baseVertices;

        for (let i = 0; i < count; i++) {
          const x = baseVertices[i * 3];
          const waveX = x * 0.0005 + mesh.userData.offset;
          const t = time * mesh.userData.speed;

          const movement =
            Math.sin(waveX + t) * mesh.userData.amplitude +
            Math.sin(waveX * 2 + t * 1.5) * (mesh.userData.amplitude * 0.5);

          positions[i * 3 + 1] = baseVertices[i * 3 + 1] + movement;
        }

        mesh.geometry.attributes.position.needsUpdate = true;
      });

      this.renderer.render(this.scene, this.camera);
    };

    private cleanup() {
      this.isPaused = true;
      if (this.animationFrameId) {
        cancelAnimationFrame(this.animationFrameId);
      }
      if (this.observer) {
        this.observer.disconnect();
      }
      if (this.resizeListener) {
        window.removeEventListener('resize', this.resizeListener);
      }
      if (this.renderer) {
        if (this.renderer.domElement && this.renderer.domElement.parentElement) {
          this.renderer.domElement.parentElement.removeChild(this.renderer.domElement);
        }
        this.renderer.dispose();
      }
      if (this.scene) {
        this.scene.traverse((object: any) => {
          if (object.geometry) {
            object.geometry.dispose();
          }
          if (object.material) {
            if (Array.isArray(object.material)) {
              object.material.forEach((m: any) => m.dispose());
            } else {
              object.material.dispose();
            }
          }
        });
      }
    }
  }

  customElements.define('psp-waves', PspWaves);
</script>
