---
// Giscus 留言元件 refactored for Tailwind 4
---

<div class="giscus-wrapper mt-12 pt-8 border-t border-slate-200 dark:border-slate-800"></div>

<script>
  // 動態載入 Giscus
  function getTheme() {
    return document.documentElement.classList.contains('dark') ? 'dark' : 'light';
  }

  function loadGiscus() {
    const giscusWrapper = document.querySelector('.giscus-wrapper');
    if (!giscusWrapper) return;

    // 清除既有的 Giscus (避免重複載入)
    giscusWrapper.innerHTML = '';

    const theme = getTheme();
    const script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.setAttribute('data-repo', 'penspulse326/penspulse326.github.io');
    script.setAttribute('data-repo-id', 'R_kgDOH7IBDw');
    script.setAttribute('data-category', 'Announcements');
    script.setAttribute('data-category-id', 'DIC_kwDOH7IBD84CesRY');
    script.setAttribute('data-mapping', 'title');
    script.setAttribute('data-strict', '0');
    script.setAttribute('data-reactions-enabled', '1');
    script.setAttribute('data-emit-metadata', '0');
    script.setAttribute('data-input-position', 'bottom');
    script.setAttribute('data-theme', theme);
    script.setAttribute('data-lang', 'zh-Hant');
    script.setAttribute('crossorigin', 'anonymous');
    script.async = true;

    giscusWrapper.appendChild(script);
  }

  // 監聽主題切換並更新 Giscus
  const observer = new MutationObserver(() => {
    const iframe = document.querySelector<HTMLIFrameElement>('.giscus-wrapper iframe');
    if (iframe?.contentWindow) {
      const theme = getTheme();
      iframe.contentWindow.postMessage({ giscus: { setConfig: { theme } } }, 'https://giscus.app');
    }
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  });

  document.addEventListener('astro:page-load', loadGiscus);
</script>
