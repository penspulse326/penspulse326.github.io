---
import Footer from '../components/footer.astro';
import Navbar from '../components/navbar/navbar.astro';
import '../styles/global.css';

interface Props {
  canonicalUrl?: string;
  description?: string;
  ogImage?: string;
  title?: string;
}

const {
  canonicalUrl = Astro.url.href,
  description = '分享技術研究筆記、程式挑戰計畫與開發心得，記錄前端開發與技術學習的點點滴滴',
  ogImage = '/avatar.png',
  title = "Pen's Pulse - 技術筆記與開發心得",
} = Astro.props;

const siteTitle = title.includes("Pen's Pulse") ? title : `${title} | Pen's Pulse`;

// 建立完整的 URL
const baseUrl = Astro.site?.href || Astro.url.origin;
const fullOgImageUrl = new URL(ogImage, baseUrl).href;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <link href="/favicon.ico" rel="icon" type="image/x-icon" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <meta content={Astro.generator} name="generator" />

    <!-- 資源提示：預先連接到自己的網域以加速資源載入 -->
    <link crossorigin href={baseUrl} rel="preconnect" />

    <!-- 主要 Meta 標籤 -->
    <title>{siteTitle}</title>
    <meta content={siteTitle} name="title" />
    <meta content={description} name="description" />
    <link href={canonicalUrl} rel="canonical" />

    <!-- Open Graph / Facebook -->
    <meta content="website" property="og:type" />
    <meta content={canonicalUrl} property="og:url" />
    <meta content={siteTitle} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content={fullOgImageUrl} property="og:image" />
    <meta content="zh_TW" property="og:locale" />

    <!-- Twitter -->
    <meta content="summary_large_image" property="twitter:card" />
    <meta content={canonicalUrl} property="twitter:url" />
    <meta content={siteTitle} property="twitter:title" />
    <meta content={description} property="twitter:description" />
    <meta content={fullOgImageUrl} property="twitter:image" />

    <!-- Theme Initialization Script -->
    <script is:inline>
      const getStoredTheme = () => localStorage.getItem('theme');
      const getPreferredTheme = () => {
        const storedTheme = getStoredTheme();
        if (storedTheme) {
          return storedTheme;
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };

      const setTheme = (theme) => {
        if (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.add('dark');
        } else if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      };

      setTheme(getPreferredTheme());
    </script>
  </head>
  <body
    class="min-h-screen flex flex-col bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100 transition-colors duration-300"
  >
    <Navbar />
    <main class="grow w-full" id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
