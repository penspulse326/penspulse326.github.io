---
interface Props {
  Content: any;
}

const { Content } = Astro.props;
---

<post-excerpt class="post-excerpt-wrapper block">
  <Content />
</post-excerpt>

<script>
  class PostExcerpt extends HTMLElement {
    connectedCallback() {
      const walker = document.createTreeWalker(this, NodeFilter.SHOW_COMMENT, null);
      let comment;
      let truncateFound = false;

      // 尋找 truncate 註解
      while ((comment = walker.nextNode())) {
        if (comment.textContent?.trim() === 'truncate') {
          truncateFound = true;
          // 隱藏此註解之後的所有兄弟元素
          let sibling = comment.nextSibling;

          while (sibling) {
            const next = sibling.nextSibling;

            if (sibling.nodeType === Node.ELEMENT_NODE) {
              (sibling as HTMLElement).style.display = 'none';
            }
            sibling = next;
          }
          break;
        }
      }

      // 將內容轉換為純文字
      const textContent = this.innerText || this.textContent || '';

      // 清空原有內容並插入純文字
      this.innerHTML = '';
      const textNode = document.createTextNode(textContent);
      this.appendChild(textNode);
    }
  }

  customElements.define('post-excerpt', PostExcerpt);
</script>

<style>
  .post-excerpt-wrapper {
    color: var(--color-slate-500);
    line-height: 1.6;
  }

  :global(:where(.dark, .dark *) post-excerpt) {
    color: var(--color-slate-400);
  }
</style>
