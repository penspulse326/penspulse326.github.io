---
import { Image } from 'astro:assets';

import type { CategoryWithContent } from '../../utils/content';
import type { CategoryPostItem } from '../../utils/posts';

import ContentMenu from './content-menu.astro';
import PostsMenu from './posts-menu.astro';
import ThemeToggler from './theme-toggler.astro';
import Search from 'astro-pagefind/components/Search';
import { Icon } from 'astro-icon/components';

import logoImage from '/public/logo.png';

const pathname = Astro.url.pathname;
const isNotesRoute = pathname.startsWith('/notes');
const isPlansRoute = pathname.startsWith('/plans');
const isPostsRoute = pathname.startsWith('/posts');
const isContentRoute = isNotesRoute || isPlansRoute;
const hasCustomMenu = isContentRoute || isPostsRoute;

const normalizePath = (path: string) => (path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path);

// 輔助函式：查找當前頁面的 active ID
const findActiveId = (navigation: CategoryWithContent[], currentPath: string) => {
  for (const category of navigation) {
    for (const item of category.items) {
      if (normalizePath(item.url) === currentPath) return item.id;
    }
  }
  return undefined;
};

let contentNavigation: CategoryWithContent[] = [];
let activeContentId: string | undefined;
let postsRecentPosts: CategoryPostItem[] = [];
let postsTagCloud: Array<{ count: number; tag: string }> = [];
let activePostId: string | undefined;

if (isNotesRoute) {
  const { getNavigation } = await import('../../utils/notes');
  contentNavigation = getNavigation().map((cat) => ({ ...cat, items: cat.notes }));
  activeContentId = findActiveId(contentNavigation, normalizePath(pathname));
} else if (isPlansRoute) {
  const { getNavigation } = await import('../../utils/plans');
  contentNavigation = getNavigation().map((cat) => ({ ...cat, items: cat.plans }));
  activeContentId = findActiveId(contentNavigation, normalizePath(pathname));
} else if (isPostsRoute) {
  const { getRecentPosts, getTagCloud } = await import('../../utils/posts');
  postsRecentPosts = getRecentPosts(5);
  postsTagCloud = getTagCloud();
  const pathParts = pathname.split('/').filter(Boolean);
  activePostId = pathParts.length > 1 ? pathParts[pathParts.length - 1] : undefined;
}
---

<nav
  class="w-full bg-white/80 dark:bg-slate-950/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 sticky top-0 z-50 transition-colors"
>
  <div class="max-w-7xl mx-auto px-4 lg:px-8">
    <!-- 手機版導覽列 (Logo, 搜尋, 選單按鈕) - 僅在小於 lg 螢幕顯示 -->
    <div class="flex lg:hidden items-center justify-between h-16 gap-4">
      <div class="shrink-0">
        <a class="flex items-center" href="/">
          <Image
            alt="Pen's Pulse Logo"
            class="h-8 w-8"
            densities={[1.5, 2, 3]}
            format="webp"
            height={32}
            quality={90}
            src={logoImage}
            width={32}
          />
        </a>
      </div>
      <div class="grow max-w-md" style="min-width: 0;">
        <Search id="mobile-nav-search" className="pagefind-custom w-full" uiOptions={{ showImages: false }} />
      </div>
      <div class="shrink-0">
        <button
          aria-controls="mobile-menu"
          aria-label="Toggle navigation"
          class="p-2 rounded-md text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 focus:outline-none"
          id="mobile-menu-button"
          type="button"
        >
          <Icon class="text-2xl" name="bi:list" />
        </button>
      </div>
    </div>

    <!-- 桌面版導覽列 - 僅在 lg 以上顯示 -->
    <div class="hidden lg:flex items-center justify-between h-16">
      <!-- 左欄 -->
      <div class="flex items-center gap-8">
        <!-- Logo -->
        <a class="flex items-center shrink-0" href="/">
          <Image
            alt="Pen's Pulse 首頁"
            class="h-8 w-8 rounded-full"
            densities={[1.5, 2, 3]}
            format="webp"
            height={32}
            quality={100}
            src={logoImage}
            width={32}
          />
          <span class="ml-3 text-xl font-bold text-slate-900 dark:text-white">Pen's Pulse</span>
        </a>

        <!-- 站內連結 -->
        <ul class="flex items-center gap-1">
          <li>
            <a
              class={`px-3 py-2 text-sm font-medium transition-colors hover:text-primary ${isPostsRoute ? 'text-primary' : 'text-slate-600 dark:text-slate-400'}`}
              href="/posts"
            >
              文章
            </a>
          </li>
          <li>
            <a
              class={`px-3 py-2 text-sm font-medium transition-colors hover:text-primary ${isNotesRoute ? 'text-primary' : 'text-slate-600 dark:text-slate-400'}`}
              href="/notes"
            >
              研究筆記
            </a>
          </li>
          <li>
            <a
              class={`px-3 py-2 text-sm font-medium transition-colors hover:text-primary ${isPlansRoute ? 'text-primary' : 'text-slate-600 dark:text-slate-400'}`}
              href="/plans"
            >
              挑戰計畫
            </a>
          </li>
        </ul>
      </div>

      <!-- 右欄 -->
      <div class="flex items-center gap-4">
        <!-- 搜尋框 -->
        <div class="w-64 relative min-h-[42px]">
          <Search id="desktop-search" className="pagefind-custom" uiOptions={{ showImages: false }} />
        </div>

        <!-- 外部連結 -->
        <a
          aria-label="前往 GitHub 查看專案"
          class="text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors"
          href="https://github.com/penspulse326"
          rel="noopener noreferrer"
          target="_blank"
        >
          <Icon class="text-xl" name="bi:github" />
        </a>

        <!-- 主題切換 -->
        <ThemeToggler />
      </div>
    </div>

    <!-- 手機版下拉選單 -->
    <div
      class="hidden border-t border-slate-200 dark:border-slate-800 lg:hidden overflow-hidden transition-all duration-300"
      id="mobile-menu"
    >
      <div class="px-2 pt-2 pb-6" id="main-menu-container">
        <div class="grid grid-cols-2 gap-3 pb-4 pt-2">
          <a
            class="flex items-center p-3 rounded-xl bg-slate-50 dark:bg-slate-900 text-slate-700 dark:text-slate-200 border border-slate-100 dark:border-slate-800"
            href="/posts"
          >
            <Icon class="mr-3 text-lg text-primary" name="bi:file-earmark-text" />
            <span class="font-medium text-sm">文章</span>
          </a>
          <a
            class="flex items-center p-3 rounded-xl bg-slate-50 dark:bg-slate-900 text-slate-700 dark:text-slate-200 border border-slate-100 dark:border-slate-800"
            href="/notes"
          >
            <Icon class="mr-3 text-lg text-primary" name="bi:journal-text" />
            <span class="font-medium text-sm">研究筆記</span>
          </a>
          <a
            class="flex items-center p-3 rounded-xl bg-slate-50 dark:bg-slate-900 text-slate-700 dark:text-slate-200 border border-slate-100 dark:border-slate-800"
            href="/plans"
          >
            <Icon class="mr-3 text-lg text-primary" name="bi:trophy" />
            <span class="font-medium text-sm">挑戰計畫</span>
          </a>
          <a
            class="flex items-center p-3 rounded-xl bg-slate-50 dark:bg-slate-900 text-slate-700 dark:text-slate-200 border border-slate-100 dark:border-slate-800"
            href="https://github.com/penspulse326"
            target="_blank"
          >
            <Icon class="mr-3 text-lg text-primary" name="bi:github" />
            <span class="font-medium text-sm">GitHub</span>
          </a>
        </div>

        {
          hasCustomMenu && (
            <button
              id="show-custom-menu"
              class="flex items-center justify-between w-full px-4 py-3 rounded-xl bg-primary/10 text-primary font-bold mb-4"
            >
              <span>✨ 顯示當前頁面專屬選單</span>
              <Icon name="bi:chevron-right" />
            </button>
          )
        }

        <div class="border-t border-slate-200 dark:border-slate-800 my-2"></div>

        <div
          class="flex items-center px-4 py-3 rounded-xl transition-colors hover:bg-slate-100 dark:hover:bg-slate-800 cursor-pointer text-slate-700 dark:text-slate-200"
          id="mobile-theme-toggle-container"
        >
          <ThemeToggler />
          <span class="ml-3 font-medium">切換深淺模式</span>
        </div>
      </div>

      <!-- 專屬選單容器 -->
      {
        isContentRoute && (
          <div id="content-menu-container" class="hidden">
            <ContentMenu activeId={activeContentId} navigation={contentNavigation} />
          </div>
        )
      }
      {
        isPostsRoute && (
          <div id="posts-menu-container" class="hidden">
            <PostsMenu activeId={activePostId} recentPosts={postsRecentPosts} tagCloud={postsTagCloud} />
          </div>
        )
      }
    </div>
  </div>
</nav>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const mainContainer = document.getElementById('main-menu-container');
  const contentContainer = document.getElementById('content-menu-container');
  const postsContainer = document.getElementById('posts-menu-container');
  const showCustomMenuBtn = document.getElementById('show-custom-menu');
  const mobileThemeToggleContainer = document.getElementById('mobile-theme-toggle-container');

  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    // 開啟時重置回主選單
    mainContainer?.classList.remove('hidden');
    if (contentContainer) contentContainer.classList.add('hidden');
    if (postsContainer) postsContainer.classList.add('hidden');
  });

  showCustomMenuBtn?.addEventListener('click', () => {
    mainContainer?.classList.add('hidden');
    if (contentContainer) contentContainer.classList.remove('hidden');
    if (postsContainer) postsContainer.classList.remove('hidden');
  });

  mobileThemeToggleContainer?.addEventListener('click', () => {
    const toggler = mobileThemeToggleContainer.querySelector('#bd-theme') as HTMLElement;
    toggler?.click();
  });
</script>

<style>
  /* Pagefind UI overrides */
  :global(.pagefind-ui) {
    --pagefind-ui-primary: var(--color-primary) !important;
    --pagefind-ui-text: var(--color-text) !important;
    --pagefind-ui-background: transparent !important;
    --pagefind-ui-border: var(--color-border) !important;
  }
</style>
