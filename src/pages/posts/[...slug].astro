---
import type { GetStaticPaths } from 'astro';

import GiscusComment from '../../components/giscus-comment.astro';
import PostsSidebar from '../../components/posts-sidebar.astro';
import TableOfContents from '../../components/table-of-contents.astro';
import ArticleLayout from '../../layouts/article-layout.astro';
import { getAllPosts, getRecentPosts, getTagCloud } from '../../utils/posts';

import { Icon } from 'astro-icon/components';

export const getStaticPaths = (async () => {
  const posts = getAllPosts();

  return posts.map((post) => {
    return {
      params: {
        slug: post.slug,
      },
      props: {
        post,
      },
    };
  });
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content, getHeadings } = post;
const headings = await getHeadings();

// 側邊欄資料
const recentPosts = getRecentPosts(5);
const tagCloud = getTagCloud();

// 格式化日期
function formatDate(date?: Date): string {
  if (!date) return '';
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}/${month}/${day}`;
}
---

<ArticleLayout
  description={post.frontmatter.description || post.frontmatter.title}
  headings={headings}
  title={post.frontmatter.title}
>
  <PostsSidebar activeId={post.id} recentPosts={recentPosts} slot="sidebar" tagCloud={tagCloud} />

  <article class="px-2 lg:px-4">
    <header class="mb-8">
      <a
        class="inline-flex items-center gap-2 text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary transition-colors mb-4 group text-sm font-medium cursor-pointer"
        href="/posts"
        id="back-button"
      >
        <Icon class="group-hover:-translate-x-1 transition-transform" name="bi:arrow-left" />
        返回
      </a>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">{post.frontmatter.title}</h1>

      <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
        {
          post.frontmatter.date && (
            <time class="flex items-center gap-1.5" datetime={post.frontmatter.date.toISOString()}>
              <Icon name="bi:calendar3" />
              {formatDate(post.frontmatter.date)} 發布
            </time>
          )
        }
        {
          post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
            <div class="flex items-center gap-2">
              <Icon name="bi:tags" />
              <div class="flex flex-wrap gap-2">
                {post.frontmatter.tags.map((tag: string, index: number) => (
                  <>
                    <a class="hover:text-primary transition-colors" href={`/posts/tag/${encodeURIComponent(tag)}`}>
                      #{tag}
                    </a>
                    {index < (post.frontmatter.tags?.length ?? 0) - 1 && <span class="opacity-30">|</span>}
                  </>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </header>

    <TableOfContents headings={headings} variant="mobile" />

    <div class="markdown-body">
      <Content />
    </div>

    <footer class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800">
      <a class="inline-flex items-center gap-2 text-primary font-medium hover:underline group" href="/posts">
        <Icon class="group-hover:-translate-x-1 transition-transform" name="bi:arrow-left" />
        返回文章列表
      </a>
    </footer>

    <GiscusComment />
  </article>
</ArticleLayout>

<script>
  // 處理返回按鈕逻辑
  const backButton = document.getElementById('back-button');
  if (backButton && document.referrer && document.referrer.includes(window.location.host)) {
    backButton.addEventListener('click', (e) => {
      // 如果來源網址是同一個網域，則執行 history.back() 以返回正確的來源（如 posts/2 或標籤頁面）
      e.preventDefault();
      history.back();
    });
  }
</script>

<style>
  /* 額外樣式已整合至 Tailwind，保留供未來擴充 */
</style>
