---
import type { CategoryPostItem } from '../../utils/posts';

interface Props {
  activeId?: string;
  recentPosts: CategoryPostItem[];
  tagCloud: Array<{ count: number; tag: string }>;
}

const { activeId, recentPosts, tagCloud } = Astro.props;
---

<button
  class="flex items-center w-full px-4 py-3 mb-4 text-sm font-semibold text-left text-slate-700 dark:text-slate-200 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors"
  id="back-to-main-menu"
  type="button"
>
  <i class="bi bi-arrow-left mr-2"></i>
  回到主選單
</button>

<div class="px-2 overflow-y-auto max-h-[calc(100vh-250px)]">
  <!-- 近期文章 -->
  <div class="mb-6">
    <h3 class="text-xs font-bold uppercase tracking-wider text-primary border-b-2 border-primary pb-2 mb-3">
      近期文章
    </h3>
    <ul class="space-y-1">
      {
        recentPosts.map((post) => (
          <li>
            <a
              class:list={[
                'block p-2 rounded-lg text-sm transition-colors hover:bg-primary/10 hover:text-primary',
                {
                  'bg-primary/10 text-primary font-semibold': activeId === post.id,
                  'text-slate-700 dark:text-slate-300': activeId !== post.id,
                },
              ]}
              href={post.url}
              title={post.title}
            >
              <div class="line-clamp-2 leading-snug">{post.title}</div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- 標籤列表 -->
  <div>
    <h3 class="text-xs font-bold uppercase tracking-wider text-primary border-b-2 border-primary pb-2 mb-3">標籤</h3>
    <ul class="space-y-1">
      {
        tagCloud.map(({ count, tag }) => (
          <li>
            <a
              class="flex items-center justify-between p-2 rounded-lg text-sm text-slate-700 dark:text-slate-300 hover:bg-primary/10 hover:text-primary transition-colors group"
              href={`/posts?tag=${encodeURIComponent(tag)}`}
              title={`${tag} (${count})`}
            >
              <span>{tag}</span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors">
                {count}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<script>
  const mainContainer = document.getElementById('main-menu-container');
  const postsContainer = document.getElementById('posts-menu-container');
  const backButton = document.getElementById('back-to-main-menu');

  if (mainContainer && postsContainer && backButton) {
    backButton.addEventListener('click', () => {
      // 切換到主選單
      postsContainer.classList.add('hidden');
      mainContainer.classList.remove('hidden');
    });
  }
</script>

<style></style>
