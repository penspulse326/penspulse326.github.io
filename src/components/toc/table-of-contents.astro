---
import type { MarkdownHeading } from 'astro';
import TocDesktop from './toc-desktop.astro';
import TocMobile from './toc-mobile.astro';

interface Props {
  headings: MarkdownHeading[];
  variant?: 'both' | 'desktop' | 'mobile';
}

const { headings, variant = 'both' } = Astro.props;

// 僅顯示 h2 和 h3 標題
const tocHeadings = headings.filter((h) => h.depth <= 3);
const showDesktop = variant === 'desktop' || variant === 'both';
const showMobile = variant === 'mobile' || variant === 'both';
---

<table-of-contents>
  {showDesktop && <TocDesktop tocHeadings={tocHeadings} />}
  {showMobile && <TocMobile tocHeadings={tocHeadings} />}
</table-of-contents>

<script>
  class TableOfContents extends HTMLElement {
    private observer: IntersectionObserver | null = null;
    private tocLinks: NodeListOf<HTMLAnchorElement> | null = null;
    private linkClickListeners = new Map<HTMLAnchorElement, (e: Event) => void>();

    connectedCallback() {
      this.tocLinks = this.querySelectorAll('.toc-link');

      this.observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const id = entry.target.getAttribute('id');
            if (!id) return;

            const tocLinks = this.querySelectorAll(`.toc-link[href="#${id}"]`);

            if (entry.isIntersecting) {
              this.tocLinks?.forEach((link) => {
                link.classList.remove('active-toc');
                link.closest('li')?.classList.remove('border-primary');
                link.closest('li')?.classList.add('border-transparent');
              });

              tocLinks.forEach((link) => {
                link.classList.add('active-toc');
                const li = link.closest('li');
                if (li) {
                  li.classList.remove('border-transparent');
                  li.classList.add('border-primary');
                }
              });
            }
          });
        },
        {
          rootMargin: '-80px 0px -80% 0px',
          threshold: 0,
        },
      );

      document.querySelectorAll('.markdown-body h2, .markdown-body h3').forEach((heading) => {
        this.observer?.observe(heading);
      });

      this.tocLinks.forEach((link) => {
        const clickListener = (e: Event) => {
          e.preventDefault();
          const targetId = link.getAttribute('href')?.slice(1);
          if (!targetId) return;

          const targetElement = document.getElementById(targetId);
          if (!targetElement) return;

          const offset = 100;
          const elementPosition = targetElement.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.scrollY - offset;

          window.scrollTo({
            behavior: 'smooth',
            top: offsetPosition,
          });

          history.pushState(null, '', `#${targetId}`);
        };

        link.addEventListener('click', clickListener);
        this.linkClickListeners.set(link, clickListener);
      });
    }

    disconnectedCallback() {
      if (this.observer) {
        this.observer.disconnect();
      }

      if (this.tocLinks) {
        this.tocLinks.forEach((link) => {
          const listener = this.linkClickListeners.get(link);
          if (listener) {
            link.removeEventListener('click', listener);
          }
        });
      }
      this.linkClickListeners.clear();
    }
  }

  customElements.define('table-of-contents', TableOfContents);
</script>

<style>
  :global(.active-toc) {
    color: var(--color-primary) !important;
    font-weight: 700;
    background-color: color-mix(in srgb, var(--color-primary) 10%, transparent);
  }

  :global(summary::-webkit-details-marker) {
    display: none;
  }
</style>
