---
import ArticleLayout from '../../layouts/article-layout.astro';
import { getNavigation } from '../../utils/plans';

const plansNav = getNavigation();
const navigation = plansNav.map((cat) => ({
  id: cat.id,
  items: cat.plans,
  label: cat.label,
}));
---

<ArticleLayout navigation={navigation} showToc={false} title="挑戰計畫">
  <section class="px-2 lg:px-6 w-full">
    <header class="mb-8">
      <h1 class="text-4xl font-black text-slate-900 dark:text-white mb-4">挑戰計畫</h1>
    </header>

    <div class="prose dark:prose-invert max-w-none text-slate-700 dark:text-slate-300 leading-relaxed">
      <p>
        這裡是我參與各種 side project、學習挑戰或是技術馬拉松的紀錄。
        <br />
        <br />
        比起單純的技術文件，這裡更多的是關於「為什麼要這麼做」的心路歷程，以及在過程中遇到的困難與解決方案。
      </p>
    </div>
  </section>
</ArticleLayout>
