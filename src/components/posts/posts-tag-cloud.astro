---
interface Props {
  tagCloud: Array<{ count: number; tag: string }>;
}

const { tagCloud } = Astro.props;
---

<nav aria-label="標籤雲">
  <h3 class="text-sm font-bold text-primary mb-2 pb-2">標籤</h3>
  <div class="flex flex-wrap gap-2">
    {
      tagCloud.map(({ count, tag }) => (
        <a
          class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 hover:border-primary hover:text-primary dark:hover:text-primary hover:bg-primary/5 transition-all"
          href={`/posts/tag/${encodeURIComponent(tag)}`}
          title={`${tag} (${count})`}
        >
          {tag}
          <span class="ml-1.5 opacity-50 px-1.5 bg-slate-200 dark:bg-slate-800 rounded-full group-hover:bg-primary/20">
            {count}
          </span>
        </a>
      ))
    }
  </div>
</nav>
