---
import { Icon } from 'astro-icon/components';

import type { CategoryWithContent } from '../../utils/content';

import ContentNavigation from '../content-navigation.astro';
interface Props {
  activeId?: string;
  navigation: CategoryWithContent[];
}

const { activeId, navigation } = Astro.props as Props;
---

<button
  class="flex items-center w-full px-4 py-3 mb-4 text-sm font-semibold text-left text-slate-700 dark:text-slate-200 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors"
  id="back-to-main-menu"
  type="button"
>
  <Icon class="mr-2" name="bi:arrow-left" />
  回到主選單
</button>

<div class="px-2 overflow-y-auto max-h-[calc(100vh-250px)]">
  <ContentNavigation activeId={activeId} id="content-drawer-accordion" navigation={navigation} />
</div>

<script>
  const mainContainer = document.getElementById('main-menu-container');
  const contentContainer = document.getElementById('content-menu-container');
  const backButton = document.getElementById('back-to-main-menu');

  if (mainContainer && contentContainer && backButton) {
    backButton.addEventListener('click', () => {
      // 切換到主選單
      contentContainer.classList.add('hidden');
      mainContainer.classList.remove('hidden');
    });
  }
</script>

<style>
  /* 內容抽屜樣式 */
  .content-drawer {
    max-height: calc(100dvh - 200px);
    overflow-y: auto;
  }
</style>
